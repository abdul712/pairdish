---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Article } from '../../data/articles';

interface Props {
  article: Article;
  allArticles: Article[];
}

const { article, allArticles } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://pairdish.com';
const canonicalUrl = new URL(`/articles/${article.slug}`, siteUrl).href;
const relatedArticles = allArticles.filter((item) => item.slug !== article.slug).slice(0, 3);
const articleImageUrl = new URL(article.image, siteUrl).href;
---

<BaseLayout
  title={article.title}
  description={article.description}
  keywords={article.keywords}
  ogImage={article.image}
  canonical={canonicalUrl}
  ogType="article"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Articles', url: '/articles' },
    { name: article.title, url: `/articles/${article.slug}` }
  ]}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-[var(--color-parchment)] via-[var(--color-cream)] to-white py-12 md:py-20">
    <div class="absolute -right-24 top-12 h-72 w-72 rounded-full bg-[var(--color-wine)] opacity-[0.06] blur-3xl"></div>
    <div class="absolute -left-20 bottom-0 h-64 w-64 rounded-full bg-[var(--color-gold)] opacity-[0.09] blur-3xl"></div>

    <div class="container relative z-10">
      <nav class="mb-8 flex flex-wrap items-center gap-2 text-sm text-[var(--text-muted)]">
        <a href="/" class="hover:text-[var(--color-wine)]">Home</a>
        <span>/</span>
        <a href="/articles" class="hover:text-[var(--color-wine)]">Articles</a>
        <span>/</span>
        <span class="text-[var(--color-wine)]">{article.category}</span>
      </nav>

      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <span class="badge badge-wine mb-5">{article.eyebrow}</span>
          <h1 class="text-display mb-5 text-[var(--text-primary)]">
            {article.title}
          </h1>
          <p class="mb-6 max-w-3xl text-xl leading-relaxed text-[var(--text-secondary)]">
            {article.summary}
          </p>
          <div class="mb-8 flex flex-wrap gap-3 text-sm text-[var(--text-muted)]">
            <span class="rounded-full bg-white px-4 py-2 shadow-[var(--shadow-soft)]">Updated {article.dateModified}</span>
            <span class="rounded-full bg-white px-4 py-2 shadow-[var(--shadow-soft)]">{article.readingTime}</span>
            <span class="rounded-full bg-white px-4 py-2 shadow-[var(--shadow-soft)]">{article.category}</span>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href={article.primaryTool.href} class="btn btn-primary px-6 py-3">
              {article.primaryTool.label}
            </a>
            <a href="/articles" class="btn btn-secondary px-6 py-3">
              View All 5 Guides
            </a>
          </div>
        </div>

        <figure class="overflow-hidden rounded-[2rem] border border-[var(--color-cream-dark)] bg-white p-3 shadow-[var(--shadow-heavy)]">
          <img
            src={article.image}
            alt={article.imageAlt}
            width="1200"
            height="800"
            loading="eager"
            class="h-full max-h-[520px] w-full rounded-[1.5rem] object-cover"
          />
        </figure>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 md:py-16">
    <div class="container grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
      <article class="mx-auto w-full max-w-3xl">
        <div class="mb-10 rounded-2xl border border-[var(--color-cream-dark)] bg-[var(--color-cream-soft)] p-6 shadow-[var(--shadow-soft)]">
          <h2 class="text-display mb-4 text-2xl text-[var(--text-primary)]">Quick takeaways</h2>
          <ul class="space-y-3">
            {article.quickWins.map((win) => (
              <li class="flex gap-3 text-[var(--text-secondary)]">
                <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-[var(--color-sage)] text-sm text-white">✓</span>
                <span>{win}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-12">
          {article.sections.map((section) => (
            <section>
              <h2 class="text-display mb-5 text-3xl text-[var(--text-primary)]">{section.heading}</h2>
              <div class="space-y-5">
                {section.body.map((paragraph) => (
                  <p class="text-lg leading-8 text-[var(--text-secondary)]">{paragraph}</p>
                ))}
              </div>

              {section.bullets && (
                <ul class="mt-6 grid gap-3 rounded-2xl bg-[var(--color-cream)] p-6">
                  {section.bullets.map((bullet) => (
                    <li class="flex gap-3 text-[var(--text-secondary)]">
                      <span class="mt-2 h-2 w-2 flex-none rounded-full bg-[var(--color-wine)]"></span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}

              {section.callout && (
                <blockquote class="mt-6 border-l-4 border-[var(--color-gold)] bg-[var(--color-parchment)] p-6 text-xl italic leading-relaxed text-[var(--text-primary)]">
                  {section.callout}
                </blockquote>
              )}

              {section.toolLink && (
                <a href={section.toolLink.href} class="mt-6 block rounded-2xl border border-[var(--color-wine)]/20 bg-white p-5 shadow-[var(--shadow-soft)] transition hover:-translate-y-1 hover:shadow-[var(--shadow-medium)]">
                  <span class="badge badge-gold mb-3">PairDish Tool</span>
                  <span class="block font-display text-2xl font-semibold text-[var(--color-wine)]">{section.toolLink.label}</span>
                  <span class="mt-2 block text-[var(--text-secondary)]">{section.toolLink.description}</span>
                </a>
              )}
            </section>
          ))}
        </div>

        <section class="mt-14 rounded-[2rem] bg-[var(--color-charcoal)] p-8 text-white">
          <span class="badge badge-gold mb-4">Nutrition note</span>
          <h2 class="text-display mb-3 text-3xl">Use PairDish as a planning assistant</h2>
          <p class="text-light-muted">
            PairDish calculators are designed for home cooking estimates, meal planning, and recipe comparison.
            They are not a substitute for medical nutrition advice, allergy guidance, or a personalized diet plan from a qualified professional.
          </p>
        </section>

        <section class="mt-14">
          <h2 class="text-display mb-6 text-3xl text-[var(--text-primary)]">Frequently asked questions</h2>
          <div class="space-y-4">
            {article.faqs.map((faq) => (
              <details class="group rounded-2xl bg-[var(--color-cream)] p-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-[var(--text-primary)]">
                  {faq.question}
                  <span class="text-[var(--color-wine)] transition group-open:rotate-45">+</span>
                </summary>
                <p class="mt-3 text-[var(--text-secondary)]">{faq.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </article>

      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="rounded-[2rem] border border-[var(--color-cream-dark)] bg-[var(--color-cream-soft)] p-6 shadow-[var(--shadow-soft)]">
          <span class="badge badge-sage mb-4">Calculator path</span>
          <h2 class="text-display mb-4 text-2xl text-[var(--text-primary)]">Turn the guide into action</h2>
          <div class="space-y-3">
            <a href="/tools/nutrition-calculator" class="block rounded-xl bg-white p-4 text-[var(--color-wine)] shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-medium)]">Recipe Nutrition Calculator</a>
            <a href="/tools/meal-prep" class="block rounded-xl bg-white p-4 text-[var(--color-wine)] shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-medium)]">Meal Prep Calculator</a>
            <a href="/tools/macro-calculator" class="block rounded-xl bg-white p-4 text-[var(--color-wine)] shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-medium)]">Macro Calculator</a>
            <a href="/tools/grocery-list" class="block rounded-xl bg-white p-4 text-[var(--color-wine)] shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-medium)]">Grocery List Generator</a>
          </div>
        </div>

        <div class="mt-6 rounded-[2rem] bg-white p-6 shadow-[var(--shadow-soft)]">
          <h2 class="text-display mb-4 text-2xl text-[var(--text-primary)]">More PairDish guides</h2>
          <div class="space-y-4">
            {relatedArticles.map((related) => (
              <a href={`/articles/${related.slug}`} class="group block">
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)]">{related.category}</span>
                <span class="block font-display text-xl font-semibold text-[var(--text-primary)] group-hover:text-[var(--color-wine)]">{related.title}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    description: article.description,
    image: [articleImageUrl],
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    author: {
      '@type': 'Organization',
      name: 'PairDish'
    },
    publisher: {
      '@type': 'Organization',
      name: 'PairDish',
      logo: {
        '@type': 'ImageObject',
        url: new URL('/favicon.svg', siteUrl).href
      }
    },
    mainEntityOfPage: canonicalUrl,
    articleSection: article.category,
    keywords: article.keywords.join(', ')
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: article.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer
      }
    }))
  })} />
</BaseLayout>
